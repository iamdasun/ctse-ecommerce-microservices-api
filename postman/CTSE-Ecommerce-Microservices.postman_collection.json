  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "direct_base_url",
      "value": "http://localhost",
      "type": "string"
    },
    {
      "key": "item_port",
      "value": "8081",
      "type": "string"
    },
    {
      "key": "order_port",
      "value": "8082",
      "type": "string"
    },
    {
      "key": "payment_port",
      "value": "8083",
      "type": "string"
    }
  ],
  "item": [
