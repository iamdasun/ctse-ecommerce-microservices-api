      "name": "Item Service",
      "item": [
        {
          "name": "Get All Items (via Kong)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/items",
              "host": ["{{base_url}}"],
              "path": ["api", "items"]
            }
          },
          "response": []
        },
        {
          "name": "Get Item by ID (via Kong)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/items/1",
